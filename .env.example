# Application name shown in metadata.
APP_NAME=python-hello-server-info

# Runtime environment.
# Allowed values: local, development, test, staging, production
APP_ENV=local

# Runtime mode.
# Allowed values: dev, prod
APP_MODE=dev

# Required. Server bind address.
# Use 0.0.0.0 for Docker or remote access, 127.0.0.1 for local-only access.
APP_HOST=0.0.0.0

# Required. Server port.
# When running Docker, publish the same container port:
# docker run --env-file .env -p 8002:8002 python-hello-server-info
APP_PORT=8002

# Optional PostgreSQL connectivity check.
# Uncomment POSTGRES_URI to enable /health/database and /health?database=true.
# Keep real credentials in .env or your deployment secret store.
# POSTGRES_URI=postgresql://<username>:<password>@<hostname>:<port>/<database>

# Required. Database health check connection timeout, in seconds.
DATABASE_CONNECT_TIMEOUT=5
